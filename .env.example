# Use the actual LAN/central backend address — never `localhost`.
# Agents now run with `network_mode: host`, but the backend itself may
# live on another host (and even on same-host setups, sticking to the
# LAN address keeps logs/registration consistent across environments).
BACKEND_URL=ws://192.168.0.16:3334
BACKEND_API_URL=http://192.168.0.16:3334

AGENT_HOSTNAME=
COLLECT_INTERVAL=2000
DOCKER_SOCKET=/var/run/docker.sock

# Optional. Sent in registration payload as `ip_address` if set.
# Use ONLY when the backend can't see the real peer IP — Docker Desktop on
# Windows/Mac, VPN tunnels, special NAT. Linux + network_mode=host doesn't
# need this; leave blank.
# AGENT_ADVERTISE_IP=

# Path to the host's /proc when the agent runs in a container. The cgroup
# files there are how PIDs are mapped back to containers for per-container
# GPU usage. Native installs (no container) leave this unset.
# Mount example: -v /proc:/host/proc:ro
# HOST_PROC_PATH=/host/proc

# Optional dcgm-exporter scrape URL (Prometheus text format). When set and
# reachable, the agent prefers DCGM SM_ACTIVE for host GPU usage and uses
# MIG-instance metrics for containers attached 1:1 to a MIG slice.
# DCGM_EXPORTER_URL=http://localhost:9400/metrics

# Master switch for per-container GPU collection. Defaults to true; set
# false to disable the pmon + cgroup path (e.g. on hosts without nvidia-smi
# in PATH where the debug-level probe noise is undesired).
# GPU_PER_CONTAINER_ENABLED=true
