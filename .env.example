# Use the actual LAN/central backend address — never `localhost`.
# Agents now run with `network_mode: host`, but the backend itself may
# live on another host (and even on same-host setups, sticking to the
# LAN address keeps logs/registration consistent across environments).
BACKEND_URL=ws://192.168.0.16:3334
BACKEND_API_URL=http://192.168.0.16:3334

AGENT_HOSTNAME=
COLLECT_INTERVAL=2000
DOCKER_SOCKET=/var/run/docker.sock

# Optional. Sent in registration payload as `ip_address` if set.
# Use ONLY when the backend can't see the real peer IP — Docker Desktop on
# Windows/Mac, VPN tunnels, special NAT. Linux + network_mode=host doesn't
# need this; leave blank.
# AGENT_ADVERTISE_IP=
