# Dev environment. Copy to `.env.dev` on each remote server and set
# HOSTNAME_SUFFIX + DOCKER_GID per host.

# Unique per server: 16 / 41 / 63
HOSTNAME_SUFFIX=63

# Shown to backend as agent hostname. Keeps dev identity separate from prod.
AGENT_HOSTNAME=server_63_dev

# All dev agents point at the same HyperCube backend (prod hypercube on 16).
BACKEND_URL=ws://192.168.0.16:3334
BACKEND_API_URL=http://192.168.0.16:3334

COLLECT_INTERVAL=2000
DOCKER_SOCKET=/var/run/docker.sock

# Docker group GID on the host. Check with `getent group docker | cut -d: -f3`.
# 16: 999, 41: 999, 63: 138
DOCKER_GID=138

LOG_LEVEL=debug
